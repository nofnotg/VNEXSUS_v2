{
  "name": "vnexus-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@prisma/client": "^6.16.2"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:contracts": "vitest run packages/domain/src/contracts.test.ts packages/domain/src/dates/date-extraction.test.ts packages/domain/src/entities/entity-extraction.test.ts packages/domain/src/windows/date-centered-window.test.ts packages/domain/src/events/event-atom-builder.test.ts packages/domain/src/bundles/event-bundle-builder.test.ts packages/domain/src/output/investigator-slot-builder.test.ts packages/domain/src/output/consumer-summary-builder.test.ts",
    "test:epic1": "vitest run packages/domain/src/contracts.test.ts packages/domain/src/documents/invariants.test.ts apps/web/lib/server/services/ingestion-order.test.ts apps/web/lib/server/services/upload-service.test.ts apps/web/lib/server/services/ocr-ingestion-service.test.ts apps/web/app/api/cases/[caseId]/upload/route.test.ts",
    "test:epic2": "vitest run packages/domain/src/contracts.test.ts packages/domain/src/dates/date-extraction.test.ts packages/domain/src/entities/entity-extraction.test.ts packages/domain/src/windows/date-centered-window.test.ts packages/domain/src/events/event-atom-builder.test.ts packages/domain/src/bundles/event-bundle-builder.test.ts packages/domain/src/output/investigator-slot-builder.test.ts packages/domain/src/output/consumer-summary-builder.test.ts apps/web/lib/server/services/date-extraction-service.test.ts apps/web/lib/server/services/entity-extraction-service.test.ts apps/web/lib/server/services/date-centered-window-service.test.ts apps/web/lib/server/services/event-atom-service.test.ts apps/web/lib/server/services/event-bundle-service.test.ts apps/web/lib/server/services/investigator-output-service.test.ts apps/web/lib/server/services/consumer-output-service.test.ts apps/web/lib/server/services/ocr-ingestion-service.test.ts",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "prisma": "^6.16.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
