{
  "name": "vnexus-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "dependencies": {
    "@prisma/client": "^6.16.2"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:contracts": "vitest run packages/domain/src/contracts.test.ts packages/domain/src/dates/date-extraction.test.ts packages/domain/src/entities/entity-extraction.test.ts packages/domain/src/windows/date-centered-window.test.ts packages/domain/src/events/event-atom-builder.test.ts packages/domain/src/bundles/event-bundle-builder.test.ts packages/domain/src/output/investigator-slot-builder.test.ts packages/domain/src/output/consumer-summary-builder.test.ts packages/domain/src/output/renderers/investigator-report-renderer.test.ts packages/domain/src/output/renderers/consumer-report-renderer.test.ts",
    "test:epic1": "vitest run packages/domain/src/contracts.test.ts packages/domain/src/documents/invariants.test.ts apps/web/lib/server/services/ingestion-order.test.ts apps/web/lib/server/services/upload-service.test.ts apps/web/lib/server/services/ocr-ingestion-service.test.ts apps/web/app/api/cases/[caseId]/upload/route.test.ts",
    "test:epic2": "vitest run packages/domain/src/contracts.test.ts packages/domain/src/dates/date-extraction.test.ts packages/domain/src/entities/entity-extraction.test.ts packages/domain/src/windows/date-centered-window.test.ts packages/domain/src/events/event-atom-builder.test.ts packages/domain/src/bundles/event-bundle-builder.test.ts packages/domain/src/output/investigator-slot-builder.test.ts packages/domain/src/output/consumer-summary-builder.test.ts packages/domain/src/output/renderers/investigator-report-renderer.test.ts packages/domain/src/output/renderers/consumer-report-renderer.test.ts apps/web/lib/server/services/date-extraction-service.test.ts apps/web/lib/server/services/entity-extraction-service.test.ts apps/web/lib/server/services/date-centered-window-service.test.ts apps/web/lib/server/services/event-atom-service.test.ts apps/web/lib/server/services/event-bundle-service.test.ts apps/web/lib/server/services/investigator-output-service.test.ts apps/web/lib/server/services/consumer-output-service.test.ts apps/web/lib/server/services/investigator-report-service.test.ts apps/web/lib/server/services/consumer-report-service.test.ts apps/web/lib/server/services/ocr-ingestion-service.test.ts apps/web/app/api/cases/[caseId]/reports/investigator/route.test.ts apps/web/app/api/cases/[caseId]/reports/consumer/route.test.ts",
    "test:epic3": "vitest run apps/web/app/cases/[caseId]/reports/investigator/page.test.tsx apps/web/app/cases/[caseId]/reports/consumer/page.test.tsx",
    "test:epic4": "vitest run packages/domain/src/output/narrative/investigator-narrative-builder.test.ts packages/domain/src/output/narrative/consumer-narrative-builder.test.ts apps/web/app/api/cases/[caseId]/reports/investigator/narrative/route.test.ts apps/web/app/api/cases/[caseId]/reports/consumer/narrative/route.test.ts",
    "test:epic5": "vitest run packages/domain/src/output/export/pdf-builder.test.ts apps/web/app/api/cases/[caseId]/reports/investigator/narrative/pdf/route.test.ts apps/web/app/api/cases/[caseId]/reports/consumer/narrative/pdf/route.test.ts",
    "test:epic6": "vitest run packages/domain/src/output/narrative/investigator-narrative-builder.test.ts packages/domain/src/output/narrative/consumer-narrative-builder.test.ts packages/domain/src/output/export/pdf-builder.test.ts apps/web/components/locale-provider.test.tsx apps/web/app/cases/[caseId]/reports/investigator/narrative/page.test.tsx apps/web/app/cases/[caseId]/reports/consumer/narrative/page.test.tsx apps/web/app/api/cases/[caseId]/reports/investigator/narrative/route.test.ts apps/web/app/api/cases/[caseId]/reports/consumer/narrative/route.test.ts apps/web/app/api/cases/[caseId]/reports/investigator/narrative/pdf/route.test.ts apps/web/app/api/cases/[caseId]/reports/consumer/narrative/pdf/route.test.ts",
    "test:epic7": "vitest run apps/web/lib/server/services/case-list-service.test.ts apps/web/lib/server/services/user-preferences-service.test.ts apps/web/app/api/cases/list/route.test.ts apps/web/app/api/user/preferences/route.test.ts apps/web/components/locale-provider.test.tsx apps/web/app/cases/page.test.tsx apps/web/app/settings/page.test.tsx",
    "test:epic8": "vitest run apps/web/lib/server/services/case-detail-service.test.ts apps/web/app/api/cases/[caseId]/detail/route.test.ts apps/web/app/api/cases/[caseId]/events/[eventId]/confirmation/route.test.ts apps/web/app/cases/[caseId]/page.test.tsx",
    "test:e2e": "playwright test",
    "typecheck": "turbo run typecheck",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "@vitejs/plugin-react": "^5.0.2",
    "prisma": "^6.16.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
