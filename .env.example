NODE_ENV=development
APP_BASE_URL=http://localhost:3000
LOCAL_DEMO_MODE=true

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vnexus_v2
REDIS_URL=redis://localhost:6379

AUTH_SECRET=replace-with-long-random-string
SESSION_COOKIE_NAME=vnexus_session

STORAGE_DRIVER=gcs
STORAGE_BUCKET=vnexus-v2-documents
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/storage
STORAGE_REGION=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg

OCR_PROVIDER=google-vision
OCR_MODE=mock
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_SPOT_RESOLVER=gpt-5-mini
OPENAI_MODEL_CASE_HELPER=gpt-5-mini
ANALYTICS_PRESET_CACHE_TTL_MS=60000
ANALYTICS_EXPORT_MAX_DAYS=366
ANALYTICS_EXPORT_MAX_FILTER_VALUES=20
ANALYTICS_SLOW_QUERY_MS=400
ANALYTICS_ALERT_WEBHOOK_URL=

PRECISION_AMBIGUITY_THRESHOLD=0.65
REVIEW_REQUIRED_EVIDENCE_MIN_COUNT=1

CONSENT_TERMS_VERSION=v1
CONSENT_PRIVACY_VERSION=v1
CONSENT_SENSITIVE_VERSION=v1
CONSENT_AI_NOTICE_VERSION=v1
CONSENT_EXPERT_CONNECTION_VERSION=v1
